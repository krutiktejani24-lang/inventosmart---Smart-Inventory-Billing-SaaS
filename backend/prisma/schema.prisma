generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────
enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum POStatus {
  PENDING
  RECEIVED
  CANCELLED
}

// ── Models ────────────────────────────────────────────────────────────
model Business {
  id         String   @id @default(cuid())
  name       String
  gstin      String?
  address    String?
  phone      String?
  email      String?
  upi_id     String?
  logo_url   String?
  plan       String   @default("free")
  created_at DateTime @default(now())

  users           User[]
  categories      Category[]
  products        Product[]
  customers       Customer[]
  vendors         Vendor[]
  invoices        Invoice[]
  stock_movements StockMovement[]
  purchase_orders PurchaseOrder[]
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  role        Role     @default(STAFF)
  is_active   Boolean  @default(true)
  business_id String
  created_at  DateTime @default(now())

  business Business @relation(fields: [business_id], references: [id])

  @@index([business_id])
}

model Category {
  id          String @id @default(cuid())
  name        String
  business_id String

  business Business  @relation(fields: [business_id], references: [id])
  products Product[]
}

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String?
  hsn_code      String?
  description   String?
  price         Float    @default(0)
  cost_price    Float    @default(0)
  stock_qty     Int      @default(0)
  min_threshold Int      @default(5)
  unit          String   @default("Pcs")
  gst_rate      Float    @default(0)
  image_url     String?
  is_active     Boolean  @default(true)
  category_id   String?
  business_id   String
  created_at    DateTime @default(now())

  category        Category?       @relation(fields: [category_id], references: [id])
  business        Business        @relation(fields: [business_id], references: [id])
  invoice_items   InvoiceItem[]
  stock_movements StockMovement[]
  po_items        POItem[]

  @@index([business_id])
  @@index([sku])
}
model Customer {
  id          String  @id @default(cuid())
  name        String
  phone       String?
  email       String?
  gstin       String?
  address     String?
  city        String?
  state       String?
  balance     Float   @default(0)
  business_id String

  business Business  @relation(fields: [business_id], references: [id])
  invoices Invoice[]

  @@index([business_id])
}

model Vendor {
  id          String  @id @default(cuid())
  name        String
  phone       String?
  email       String?
  gstin       String?
  address     String?
  balance     Float   @default(0)
  business_id String

  business        Business        @relation(fields: [business_id], references: [id])
  purchase_orders PurchaseOrder[]

  @@index([business_id])
}

model Invoice {
  id                String        @id @default(cuid())
  invoice_no        String        @unique
  customer_id       String
  business_id       String
  subtotal          Float         @default(0)
  discount          Float         @default(0)
  cgst              Float         @default(0)
  sgst              Float         @default(0)
  igst              Float         @default(0)
  total             Float         @default(0)
  status            InvoiceStatus @default(DRAFT)

  place_of_supply   String?
  is_igst           Boolean @default(false)

  notes             String?
  pdf_url           String?
  due_date          DateTime?
  created_at        DateTime      @default(now())

  customer Customer @relation(fields: [customer_id], references: [id])
  business Business @relation(fields: [business_id], references: [id])

  items    InvoiceItem[]
  payments Payment[]

  @@index([business_id])
  @@index([status])
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoice_id String
  product_id String?
  name       String
  hsn_code   String?
  qty        Int
  price      Float
  discount   Float   @default(0)
  gst_rate   Float   @default(0)
  cgst       Float   @default(0)
  sgst       Float   @default(0)
  igst       Float   @default(0)
  total      Float

  invoice Invoice  @relation(fields: [invoice_id], references: [id])
  product Product? @relation(fields: [product_id], references: [id])
}

model StockMovement {
  id           String            @id @default(cuid())
  product_id   String
  business_id  String
  type         StockMovementType
  qty          Int
  before_qty   Int
  after_qty    Int
  reason       String?
  reference_id String?
  created_by   String?
  created_at   DateTime          @default(now())

  product  Product  @relation(fields: [product_id], references: [id])
  business Business @relation(fields: [business_id], references: [id])

  @@index([product_id])
}

model PurchaseOrder {
  id          String   @id @default(cuid())
  po_number   String   @unique
  vendor_id   String
  business_id String
  total       Float    @default(0)
  status      POStatus @default(PENDING)
  notes       String?
  created_at  DateTime @default(now())

  vendor   Vendor   @relation(fields: [vendor_id], references: [id])
  business Business @relation(fields: [business_id], references: [id])
  items    POItem[]

  @@index([business_id])
}

model POItem {
  id           String @id @default(cuid())
  po_id        String
  product_id   String
  qty          Int
  price        Float
  received_qty Int    @default(0)

  po      PurchaseOrder @relation(fields: [po_id], references: [id])
  product Product       @relation(fields: [product_id], references: [id])
}

model Payment {
  id         String   @id @default(cuid())
  invoice_id String
  amount     Float
  method     String   @default("CASH")
  reference  String?
  notes      String?
  created_at DateTime @default(now())

  invoice Invoice @relation(fields: [invoice_id], references: [id])

  @@index([invoice_id])
}
